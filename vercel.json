{
  "installCommand": "npm install && npx prisma generate --schema=apps/api/prisma/schema.prisma",
  "buildCommand": "cd apps/web && npx next build",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    }
  ]
}
