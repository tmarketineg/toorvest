{
  "installCommand": "npm install",
  "buildCommand": "cd apps/api && npx prisma generate && cd ../../apps/web && npx next build",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    }
  ]
}
