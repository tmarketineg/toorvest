{
  "installCommand": "npm install && cd apps/api && npx prisma generate",
  "buildCommand": "cd apps/web && npx next build",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    },
    {
      "src": "/api/uploads/(.*)",
      "dest": "/api"
    }
  ]
}
